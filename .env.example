# ═══════════════════════════════════════════════════════════════
# ARTH — AI Research & Trading Hub
# Environment Configuration
# ═══════════════════════════════════════════════════════════════

# ── Application ──
APP_NAME=ARTH
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── FastAPI ──
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Database (TimescaleDB) ──
DATABASE_URL=postgresql+asyncpg://arth_user:arth_dev_password@localhost:5432/arth
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL_TICK=15
REDIS_CACHE_TTL_INDICATORS=60
REDIS_CACHE_TTL_FUNDAMENTALS=86400

# ── LLM Configuration ──
# Tier routing: local → cloud → premium
LLM_TIER=cloud

# Groq (Primary in Phase 1 — free tier: 14,400 req/day)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=4096

# Ollama (Local dev fallback)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# Claude API (Phase 2+ — deep research only)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (Embeddings for Phase 2 RAG)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Data Sources ──
# Yahoo Finance — no API key needed (yfinance library)
YAHOO_FINANCE_ENABLED=true

# Alpha Vantage — deferred to Phase 2
ALPHA_VANTAGE_API_KEY=
ALPHA_VANTAGE_DAILY_BUDGET=20
ALPHA_VANTAGE_ENABLED=false

# NewsAPI — for sentiment engine
NEWSAPI_KEY=your_newsapi_key_here
NEWSAPI_ENABLED=true

# ── Security ──
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
RATE_LIMIT_PER_MINUTE=100

# ── WebSocket ──
WS_HEARTBEAT_INTERVAL=30
WS_RECONNECT_MAX_RETRIES=5

# ── Data Quality ──
DATA_FRESHNESS_THRESHOLD_LIVE=60
DATA_FRESHNESS_THRESHOLD_FUNDAMENTALS=86400
PRICE_ANOMALY_THRESHOLD_PCT=20.0
